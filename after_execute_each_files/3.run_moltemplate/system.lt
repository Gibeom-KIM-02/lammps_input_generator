###############################################################
#  system.lt (auto-generated by make_system_lt.py)
#  Source XYZ : Ag_sulfate_CO2_solvated.xyz
###############################################################

# ------------------------------------------------------------
# GLOBAL FORCE-FIELD SETTINGS  (must precede all pair_coeff)
# ------------------------------------------------------------
write_once("In Settings") {
  pair_style lj/cut/coul/long 10.0
  pair_modify mix geometric
  special_bonds lj/coul 0.0 0.0 0.5
  kspace_style pppm 0.0001
  bond_style harmonic
  angle_style harmonic
  dihedral_style opls
  improper_style cvff
}
# ------------------------------------------------------------
# BOX DIMENSIONS  (auto-detected, ±2 Å padding)
# ------------------------------------------------------------
write_once("Data Boundary") {
  -2.0 31.994209 xlo xhi
  -2.0 31.998125 ylo yhi
  -2.0 31.958305 zlo zhi
}

# ------------------------------------------------------------
# MOLECULE DEFINITIONS
# !! NOTE !!  Paths are relative to the directory where you run moltemplate.sh.
# ------------------------------------------------------------
import "input_files_lt_adsorbent/Ag.lt"   # <-- Adjust path if needed!
import "input_files_lt/CO2.lt"   # <-- Adjust path if needed!
import "input_files_lt/tip3p_2004_oplsaa2024.lt"   # <-- Adjust path if needed!
import "input_files_lt/sulfate.lt"   # <-- Adjust path if needed!

# ------------------------------------------------------------
# INSTANTIATE OBJECTS  (must match XYZ ordering!)
# ------------------------------------------------------------
Agblock = new Ag[1]  # 48 Ag atoms total (48/slab)
CO2ads = new CO2[1]
Waters = new TIP3P[100]
SO4 = new sulfate[4]

# ------------------------------------------------------------
# FIX SLAB ATOMS (edit 'fixed_group' in YAML as needed)
# ------------------------------------------------------------
write_once("In Settings") {
  group fixed_AgSlab id 1:32
  fix   hold_AgSlab fixed_AgSlab setforce 0 0 0
}
###############################################################
#  BUILD INSTRUCTIONS
#  Run: moltemplate.sh -xyz Ag_sulfate_CO2_solvated.xyz -atomstyle "full" system.lt
#
#  CHECKLIST
#  1) XYZ atom order  : AgSlab → CO2 → TIP3P_2004 → Sulfate
#  2) Net charge      : verify in molecules.yaml (add counter-ions if needed)
#  3) SHAKE for water : see water .lt for fix name (e.g. fShakeTIP3P_2004)
#  4) Adjust 'fixed_group' if slab size changes
#  5) IMPORT paths above must be correct for your run directory
