# LAMMPS Minimization Input
# -------------------------

variable datapath string build      # <-- Set build directory here

include         "build/system.in.init"
read_data       "build/system.data"
include         "build/system.in.settings"

# Minimization
unfix fShakeTIP3P 
minimize        1.0e-4 1.0e-6 10000 100000

# Write minimized structure
write_data      system_after_min.data


