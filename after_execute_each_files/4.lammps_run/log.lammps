LAMMPS (10 Sep 2025)
  using 1 OpenMP thread(s) per MPI task
# in.min_npt_nvt
# ============================================================
# Uses ONLY:
#   ${datapath}/system.data
#   ${datapath}/system.in.init
#   ${datapath}/system.in.settings
#
# Workflow:
#   (1) Minimization (SHAKE off if defined)
#   (2) NPT equilibration @ 300 K, 1 atm (bulk 3D PBC assumed)
#   (3) NVT production @ 300 K (RDF sampling)
# ============================================================

# ---- Where the build files live (default: build/) ----

# ============================================================
# STAGE 1) MINIMIZATION
# ============================================================

include         "build/system.in.init"
units           real
atom_style      full

bond_style      harmonic
angle_style     harmonic
dihedral_style  opls
improper_style  cvff

pair_style      lj/cut/coul/long 11.0 11.0
pair_modify     mix geometric
special_bonds   lj/coul 0.0 0.0 0.5
kspace_style    pppm 1.0e-4
read_data       "build/system.data"
