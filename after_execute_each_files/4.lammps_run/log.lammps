# If your settings file defines SHAKE for water (e.g., fix fShakeTIP3P),
# minimization is often done with SHAKE turned OFF.
# If this unfix errors, just comment it out.
unfix           fShakeTIP3P

# Neighbor list hygiene
neigh_modify    delay 0 every 1 check yes

min_style       cg
minimize        1.0e-4 1.0e-6 10000 100000
