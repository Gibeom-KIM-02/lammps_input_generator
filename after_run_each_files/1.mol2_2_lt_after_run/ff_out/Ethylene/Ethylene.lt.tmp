
  ### LAMMPS commands for initialization
  ### (These can be overridden later.)


write_once("In Init") {
  atom_style full
}

write_once("In Settings") {
  pair_coeff @atom:type1 @atom:type1 0.076 3.5500000
  pair_coeff @atom:type2 @atom:type2 0.076 3.5500000
  pair_coeff @atom:type3 @atom:type3 0.030 2.5000000
  pair_coeff @atom:type4 @atom:type4 0.030 2.5000000
  pair_coeff @atom:type5 @atom:type5 0.030 2.5000000
  pair_coeff @atom:type6 @atom:type6 0.030 2.5000000
}

write_once("In Settings") {
  bond_coeff @bond:type1 549.0000 1.3400
  bond_coeff @bond:type2 340.0000 1.0800
  bond_coeff @bond:type3 340.0000 1.0800
  bond_coeff @bond:type4 340.0000 1.0800
  bond_coeff @bond:type5 340.0000 1.0800
}

write_once("In Settings") {
  angle_coeff @angle:type1 35.000 120.000
  angle_coeff @angle:type2 35.000 120.000
  angle_coeff @angle:type3 35.000 120.000
  angle_coeff @angle:type4 35.000 120.000
  angle_coeff @angle:type5 35.000 117.000
  angle_coeff @angle:type6 35.000 117.000
}

write_once("In Settings") {
  dihedral_coeff @dihedral:type1 0.000 14.000 0.000 0.000
  dihedral_coeff @dihedral:type2 0.000 14.000 0.000 0.000
  dihedral_coeff @dihedral:type3 0.000 14.000 0.000 0.000
  dihedral_coeff @dihedral:type4 0.000 14.000 0.000 0.000
}

write_once("In Settings") {
  improper_coeff @improper:type1 2.500 -1 2
  improper_coeff @improper:type2 2.500 -1 2
}


  ### DATA sections


write_once("Data Masses") {
  @atom:type1 12.011
  @atom:type2 12.011
  @atom:type3 1.008
  @atom:type4 1.008
  @atom:type5 1.008
  @atom:type6 1.008
}

write("Data Atoms") {
  $atom:type1 $mol:m1 @atom:type1 -0.250766 -0.66700 0.00000 0.00000
  $atom:type2 $mol:m1 @atom:type2 -0.250766 0.67500 0.00000 0.00000
  $atom:type3 $mol:m1 @atom:type3 0.125383 -1.22700 -0.92200 0.07000
  $atom:type4 $mol:m1 @atom:type4 0.125383 -1.22700 0.92200 -0.07000
  $atom:type5 $mol:m1 @atom:type5 0.125383 1.23400 0.92200 -0.07000
  $atom:type6 $mol:m1 @atom:type6 0.125383 1.23400 -0.92200 0.07000
}

write("Data Bonds") {
  $bond:id1 @bond:type1 $atom:type2 $atom:type1
  $bond:id2 @bond:type2 $atom:type3 $atom:type1
  $bond:id3 @bond:type3 $atom:type4 $atom:type1
  $bond:id4 @bond:type4 $atom:type5 $atom:type2
  $bond:id5 @bond:type5 $atom:type6 $atom:type2
}

write("Data Angles") {
  $angle:id1 @angle:type1 $atom:type3 $atom:type1 $atom:type2
  $angle:id2 @angle:type2 $atom:type4 $atom:type1 $atom:type2
  $angle:id3 @angle:type3 $atom:type5 $atom:type2 $atom:type1
  $angle:id4 @angle:type4 $atom:type6 $atom:type2 $atom:type1
  $angle:id5 @angle:type5 $atom:type4 $atom:type1 $atom:type3
  $angle:id6 @angle:type6 $atom:type6 $atom:type2 $atom:type5
}

write("Data Dihedrals") {
  $dihedral:id1 @dihedral:type1 $atom:type5 $atom:type2 $atom:type1 $atom:type3
  $dihedral:id2 @dihedral:type2 $atom:type6 $atom:type2 $atom:type1 $atom:type3
  $dihedral:id3 @dihedral:type3 $atom:type5 $atom:type2 $atom:type1 $atom:type4
  $dihedral:id4 @dihedral:type4 $atom:type6 $atom:type2 $atom:type1 $atom:type4
}

write("Data Impropers") {
  $improper:id1 @improper:type1 $atom:type2 $atom:type1 $atom:type3 $atom:type4
  $improper:id2 @improper:type2 $atom:type1 $atom:type2 $atom:type5 $atom:type6
}
