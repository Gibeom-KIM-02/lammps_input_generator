
  ### LAMMPS commands for initialization
  ### (These can be overridden later.)


write_once("In Init") {
  atom_style full
}

write_once("In Settings") {
  pair_coeff @atom:type1 @atom:type1 0.250 3.5500000
  pair_coeff @atom:type2 @atom:type2 0.250 3.5500000
  pair_coeff @atom:type3 @atom:type3 0.060 2.9000000
  pair_coeff @atom:type4 @atom:type4 0.060 2.9000000
  pair_coeff @atom:type5 @atom:type5 0.170 2.9600000
  pair_coeff @atom:type6 @atom:type6 0.170 2.9600000
  pair_coeff @atom:type7 @atom:type7 0.170 2.9600000
  pair_coeff @atom:type8 @atom:type8 0.170 2.9600000
  pair_coeff @atom:type9 @atom:type9 0.170 3.2500000
}

write_once("In Settings") {
  bond_coeff @bond:type1 250.0000 1.7300
  bond_coeff @bond:type2 250.0000 1.7300
  bond_coeff @bond:type3 450.0000 1.6000
  bond_coeff @bond:type4 450.0000 1.6000
  bond_coeff @bond:type5 700.0000 1.4400
  bond_coeff @bond:type6 700.0000 1.4400
  bond_coeff @bond:type7 700.0000 1.4400
  bond_coeff @bond:type8 700.0000 1.4400
}

write_once("In Settings") {
  angle_coeff @angle:type1 80.290 117.310
  angle_coeff @angle:type2 76.450 103.980
  angle_coeff @angle:type3 76.450 103.980
  angle_coeff @angle:type4 76.450 103.980
  angle_coeff @angle:type5 76.450 103.980
  angle_coeff @angle:type6 76.450 103.980
  angle_coeff @angle:type7 76.450 103.980
  angle_coeff @angle:type8 62.000 106.200
  angle_coeff @angle:type9 62.000 106.200
  angle_coeff @angle:type10 62.000 106.200
  angle_coeff @angle:type11 62.000 106.200
  angle_coeff @angle:type12 104.000 123.000
  angle_coeff @angle:type13 104.000 123.000
}

write_once("In Settings") {
  dihedral_coeff @dihedral:type1 0.000 0.000 0.000 0.000
  dihedral_coeff @dihedral:type2 0.000 0.000 0.000 0.000
  dihedral_coeff @dihedral:type3 0.000 0.000 0.000 0.000
  dihedral_coeff @dihedral:type4 0.000 0.000 0.000 0.000
  dihedral_coeff @dihedral:type5 0.000 0.000 0.000 0.000
  dihedral_coeff @dihedral:type6 0.000 0.000 0.000 0.000
}


  ### DATA sections


write_once("Data Masses") {
  @atom:type1 32.067
  @atom:type2 32.067
  @atom:type3 18.998
  @atom:type4 18.998
  @atom:type5 15.999
  @atom:type6 15.999
  @atom:type7 15.999
  @atom:type8 15.999
  @atom:type9 14.007
}

write("Data Atoms") {
  $atom:type1 $mol:m1 @atom:type1 1.825587 -1.50400 -0.06100 0.13000
  $atom:type2 $mol:m1 @atom:type2 1.825270 1.29400 -0.31400 -0.06200
  $atom:type3 $mol:m1 @atom:type3 -0.244490 -1.34700 -1.64600 -0.01300
  $atom:type4 $mol:m1 @atom:type4 -0.244431 0.84000 -0.81200 -1.51300
  $atom:type5 $mol:m1 @atom:type5 -0.506861 -2.36200 0.18400 1.26000
  $atom:type6 $mol:m1 @atom:type6 -0.506861 -1.74200 0.49100 -1.17800
  $atom:type7 $mol:m1 @atom:type7 -0.506725 2.32800 0.67000 -0.25200
  $atom:type8 $mol:m1 @atom:type8 -0.506725 1.44600 -1.46600 0.78700
  $atom:type9 $mol:m1 @atom:type9 -2.134764 0.00100 0.55600 0.60100
}

write("Data Bonds") {
  $bond:id1 @bond:type1 $atom:type1 $atom:type9
  $bond:id2 @bond:type2 $atom:type2 $atom:type9
  $bond:id3 @bond:type3 $atom:type3 $atom:type1
  $bond:id4 @bond:type4 $atom:type4 $atom:type2
  $bond:id5 @bond:type5 $atom:type5 $atom:type1
  $bond:id6 @bond:type6 $atom:type6 $atom:type1
  $bond:id7 @bond:type7 $atom:type7 $atom:type2
  $bond:id8 @bond:type8 $atom:type8 $atom:type2
}

write("Data Angles") {
  $angle:id1 @angle:type1 $atom:type2 $atom:type9 $atom:type1
  $angle:id2 @angle:type2 $atom:type3 $atom:type1 $atom:type9
  $angle:id3 @angle:type3 $atom:type4 $atom:type2 $atom:type9
  $angle:id4 @angle:type4 $atom:type5 $atom:type1 $atom:type9
  $angle:id5 @angle:type5 $atom:type6 $atom:type1 $atom:type9
  $angle:id6 @angle:type6 $atom:type7 $atom:type2 $atom:type9
  $angle:id7 @angle:type7 $atom:type8 $atom:type2 $atom:type9
  $angle:id8 @angle:type8 $atom:type5 $atom:type1 $atom:type3
  $angle:id9 @angle:type9 $atom:type6 $atom:type1 $atom:type3
  $angle:id10 @angle:type10 $atom:type7 $atom:type2 $atom:type4
  $angle:id11 @angle:type11 $atom:type8 $atom:type2 $atom:type4
  $angle:id12 @angle:type12 $atom:type6 $atom:type1 $atom:type5
  $angle:id13 @angle:type13 $atom:type8 $atom:type2 $atom:type7
}

write("Data Dihedrals") {
  $dihedral:id1 @dihedral:type1 $atom:type3 $atom:type1 $atom:type9 $atom:type2
  $dihedral:id2 @dihedral:type2 $atom:type4 $atom:type2 $atom:type9 $atom:type1
  $dihedral:id3 @dihedral:type3 $atom:type5 $atom:type1 $atom:type9 $atom:type2
  $dihedral:id4 @dihedral:type4 $atom:type6 $atom:type1 $atom:type9 $atom:type2
  $dihedral:id5 @dihedral:type5 $atom:type7 $atom:type2 $atom:type9 $atom:type1
  $dihedral:id6 @dihedral:type6 $atom:type8 $atom:type2 $atom:type9 $atom:type1
}
