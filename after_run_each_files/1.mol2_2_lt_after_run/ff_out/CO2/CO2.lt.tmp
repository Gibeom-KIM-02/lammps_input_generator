
  ### LAMMPS commands for initialization
  ### (These can be overridden later.)


write_once("In Init") {
  atom_style full
}

write_once("In Settings") {
  pair_coeff @atom:type1 @atom:type1 0.066 3.3000000
  pair_coeff @atom:type2 @atom:type2 0.210 2.9600000
  pair_coeff @atom:type3 @atom:type3 0.210 2.9600000
}

write_once("In Settings") {
  bond_coeff @bond:type1 700.0000 1.1680
  bond_coeff @bond:type2 700.0000 1.1680
}

write_once("In Settings") {
  angle_coeff @angle:type1 160.000 180.000
}


  ### DATA sections


write_once("Data Masses") {
  @atom:type1 12.011
  @atom:type2 15.999
  @atom:type3 15.999
}

write("Data Atoms") {
  $atom:type1 $mol:m1 @atom:type1 0.560076 0.00000 0.00000 0.00000
  $atom:type2 $mol:m1 @atom:type2 -0.280038 -0.03300 -1.14100 0.54700
  $atom:type3 $mol:m1 @atom:type3 -0.280038 0.03900 1.07500 0.69700
}

write("Data Bonds") {
  $bond:id1 @bond:type1 $atom:type2 $atom:type1
  $bond:id2 @bond:type2 $atom:type3 $atom:type1
}

write("Data Angles") {
  $angle:id1 @angle:type1 $atom:type3 $atom:type1 $atom:type2
}
