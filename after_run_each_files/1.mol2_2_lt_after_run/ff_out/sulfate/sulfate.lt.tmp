
  ### LAMMPS commands for initialization
  ### (These can be overridden later.)


write_once("In Init") {
  atom_style full
}

write_once("In Settings") {
  pair_coeff @atom:type1 @atom:type1 0.250 3.5500000
  pair_coeff @atom:type2 @atom:type2 0.170 2.9600000
  pair_coeff @atom:type3 @atom:type3 0.170 2.9600000
  pair_coeff @atom:type4 @atom:type4 0.170 2.9600000
  pair_coeff @atom:type5 @atom:type5 0.170 2.9600000
}

write_once("In Settings") {
  bond_coeff @bond:type1 700.0000 1.4400
  bond_coeff @bond:type2 700.0000 1.4400
  bond_coeff @bond:type3 700.0000 1.4400
  bond_coeff @bond:type4 700.0000 1.4400
}

write_once("In Settings") {
  angle_coeff @angle:type1 104.000 123.000
  angle_coeff @angle:type2 104.000 123.000
  angle_coeff @angle:type3 104.000 123.000
  angle_coeff @angle:type4 104.000 123.000
  angle_coeff @angle:type5 104.000 123.000
  angle_coeff @angle:type6 104.000 123.000
}


  ### DATA sections


write_once("Data Masses") {
  @atom:type1 32.067
  @atom:type2 15.999
  @atom:type3 15.999
  @atom:type4 15.999
  @atom:type5 15.999
}

write("Data Atoms") {
  $atom:type1 $mol:m1 @atom:type1 1.384505 0.00000 0.00000 0.00000
  $atom:type2 $mol:m1 @atom:type2 -0.846126 1.26500 -0.59600 -0.34200
  $atom:type3 $mol:m1 @atom:type3 -0.846126 0.10100 0.63600 1.28800
  $atom:type4 $mol:m1 @atom:type4 -0.846126 -0.35200 0.98100 -0.99300
  $atom:type5 $mol:m1 @atom:type5 -0.846127 -1.01500 -1.02100 0.04600
}

write("Data Bonds") {
  $bond:id1 @bond:type1 $atom:type2 $atom:type1
  $bond:id2 @bond:type2 $atom:type3 $atom:type1
  $bond:id3 @bond:type3 $atom:type4 $atom:type1
  $bond:id4 @bond:type4 $atom:type5 $atom:type1
}

write("Data Angles") {
  $angle:id1 @angle:type1 $atom:type3 $atom:type1 $atom:type2
  $angle:id2 @angle:type2 $atom:type4 $atom:type1 $atom:type2
  $angle:id3 @angle:type3 $atom:type5 $atom:type1 $atom:type2
  $angle:id4 @angle:type4 $atom:type4 $atom:type1 $atom:type3
  $angle:id5 @angle:type5 $atom:type5 $atom:type1 $atom:type3
  $angle:id6 @angle:type6 $atom:type5 $atom:type1 $atom:type4
}
